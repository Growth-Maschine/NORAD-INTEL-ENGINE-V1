# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Comma-separated JSON array of allowed CORS origins.
# Local dev:  ["http://localhost:5000","http://127.0.0.1:5000"]
# Production: ["https://your-frontend.vercel.app"]
CORS_ORIGINS=["http://localhost:5000","http://127.0.0.1:5000"]

# ── LLM + research engines ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
PARALLEL_API_KEY=...
EXA_API_KEY=...
# Diffbot Knowledge Graph token — third research engine alongside Parallel/Exa.
# Grab from https://app.diffbot.com/ → Account → API Token.
DIFFBOT_API_KEY=...

# ── Supabase (hosted Postgres) ───────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_PUBLISHABLE_KEY=...
SUPABASE_SECRET_KEY=...
SUPABASE_JWT_SECRET=...

# Runtime: transaction pooler (port 6543) — used by the app for queries.
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@aws-...pooler.supabase.com:6543/postgres
# DDL from Replit / IPv4-only hosts: session pooler (port 5432).
SUPABASE_DATABASE_URL_pool=postgresql://postgres.<ref>:<pw>@aws-...pooler.supabase.com:5432/postgres
# Direct connection (IPv6) — only works from environments with IPv6.
SUPABASE_DATABASE_URL_DIRECT=postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL=rediss://default:<token>@<endpoint>.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://<endpoint>.upstash.io
UPSTASH_REDIS_REST_TOKEN=...
