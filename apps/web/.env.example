# Base URL of the FastAPI backend. Required in production (e.g. Vercel).
# Leave UNSET for local dev — Vite proxies /api and /health to localhost:8000.
#
# Examples:
#   Local + vite proxy:   (leave unset / empty)
#   Railway:              VITE_API_URL=https://norad-api.up.railway.app
#   Same-origin prod:     (leave unset — backend serves the built frontend)
VITE_API_URL=
